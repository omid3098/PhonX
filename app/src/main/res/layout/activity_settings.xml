<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Back button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/content_desc_back"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textAppearance="@style/TextAppearance.PhonX.Title"
            android:textSize="22sp"
            android:gravity="center" />

        <!-- Spacer to balance back button -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- Current server card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/input_bg"
        app:cardCornerRadius="12dp"
        app:strokeWidth="0dp"
        app:cardElevation="0dp"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/current_server"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCurrentServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_server"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="middle" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Server URI input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="24dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:hint="@string/settings_hint"
        app:boxStrokeColor="@color/md_primary"
        app:hintTextColor="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etServerUri"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:inputType="textMultiLine|textNoSuggestions"
            android:gravity="top"
            android:textIsSelectable="true"
            android:minLines="5" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/save_back"
        android:textSize="18sp" />

</LinearLayout>
